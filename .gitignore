# Apptainer SIF — built by characterization/apptainer/build-sif.sh.
# The SIF itself is large (~5 GB) and content-addressed; only the
# lockfile (characterization/canonical-image.lock) is committed.
*.sif

# Apptainer build cache / scratch
.apptainer-cache/

# Rust build artifacts
/target/

# Per-developer Cargo config (e.g. local target-dir redirect).
# Use CARGO_TARGET_DIR env var or a local .cargo/config.toml for per-rig overrides.
.cargo/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Gas City
.beads/*
!.beads/config.yaml
!.beads/metadata.json

# Gas City
!.beads/identity.toml

# Default output directory for moves run
moves-output/

# Execution-DB Arrow-IPC bundle (derived from committed Parquet files).
# Generate with: moves-snapshot bundle-update <snapshot-dir...>
execution-db.bundle
