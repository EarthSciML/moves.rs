# Pinned toolchain + source versions for canonical-moves.sif.
#
# This file is sourced by both build-sif.sh and the def file's %post
# (via a copied-in copy at /opt/moves-bin/versions.env). Update these
# values together with characterization/canonical-image.lock — the lock
# records the SHA256 of the SIF that this exact version set produces.
#
# Reproducibility note: the SIF SHA256 is the source of truth. Component
# checksums below are belt-and-suspenders; if they drift, the SIF will
# also drift and the lockfile mismatch will catch it.

# ----- MOVES source -----
# EPA's official repository. Pin to a specific commit SHA (40 hex chars).
# Bumping this is a deliberate cutover; downstream characterization
# snapshots taken against the prior SIF SHA become non-authoritative.
# See characterization/apptainer/README.md "Pinning the MOVES source".
MOVES_REPO_URL="https://github.com/USEPA/EPA_MOVES_Model.git"
# MOVES5.0.1 release tip on master (2025-11-14, message "MOVES5.0.1 with movesdb20241112")
MOVES_COMMIT="25dc6c833dd8c88198f82cee93ca30be1456df8b"

# ----- Default database -----
# The MOVES default DB ZIP. Three supply paths in priority order:
#   1. MOVESDB_LOCAL_PATH (host dir or zip) -> bind-mounted at build time.
#   2. database/Setup/movesdb20241112.zip in the cloned MOVES tree.
#   3. MOVESDB_URL set to a hosted copy -> downloaded during %post.
# SHA256 verification is enforced in all three paths. The zip is 30 MB
# compressed and contains a single 390 MB movesdb20241112.sql dump.
MOVESDB_FILENAME="movesdb20241112.zip"
MOVESDB_SHA256="f42f6a796261a547706807d90eed27124f73ea9518da04f2f5c877fc9b0ca55a"
MOVESDB_URL=""

# ----- MariaDB 11.4 -----
# Installed from MariaDB's official APT repo. The minor version floats
# within 11.4.x (LTS series); the SIF SHA256 captures the exact version
# that built the image.
MARIADB_SERIES="11.4"

# ----- JDK 17 (Eclipse Temurin) -----
# Installed from Adoptium's APT repo; minor version floats within 17.x.
JDK_PACKAGE="temurin-17-jdk"

# ----- Go 1.21 -----
# Downloaded as a tarball from go.dev. 1.21.13 is the final 1.21 patch.
# SHA256 from https://go.dev/dl/?mode=json&include=all (verified at build time).
GO_VERSION="1.21.13"
GO_TARBALL="go${GO_VERSION}.linux-amd64.tar.gz"
GO_DOWNLOAD_URL="https://go.dev/dl/${GO_TARBALL}"
GO_SHA256="502fc16d5910562461e6a6631fb6377de2322aad7304bf2bcd23500ba9dab4a7"
