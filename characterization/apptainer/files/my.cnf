# MOVES-tuned MariaDB configuration.
#
# Loaded inside the SIF at /etc/mysql/mariadb.conf.d/99-moves.cnf so it
# overrides the distribution defaults. Settings here are derived from
# EPA's published MOVES installation guide and from the constraints of
# loading the ~390 MB movesdb20241112 dump and running calculator-chain
# queries that produce multi-GB intermediate results.
#
# Bind mounts (set by run-moves.sh / the validation command):
#   /var/lib/mysql        <- writable host path (datadir)
#   /var/run/mysqld       <- writable host path (socket + pidfile)

[mysqld]

# --- MOVES requirements ---
# LOAD DATA INFILE / SELECT INTO OUTFILE are used heavily by MOVES
# to move data between the default, execution, and worker databases.
local_infile      = 1
secure_file_priv  =

# MOVES schema files use "STRICT_TRANS_TABLES,NO_AUTO_VALUE_ON_ZERO"
# semantics implicitly. An empty sql_mode keeps MariaDB's strict
# defaults out of the way for the dumps we ingest.
sql_mode          =

# Several MOVES tables exceed the default 16 MB packet limit.
max_allowed_packet = 1G

# MOVES schema is mixed-case-sensitive; the codebase assumes
# case-insensitive table names (matches MariaDB on Windows).
lower_case_table_names = 1

# --- InnoDB tuning ---
# Buffer pool: large enough to hold the hot working set for a
# Sample-RunSpec-class run. Override at runtime via my.cnf bind mount
# for fat-node fixture runs.
innodb_buffer_pool_size      = 2G
innodb_log_file_size         = 512M
innodb_flush_log_at_trx_commit = 2
innodb_file_per_table        = 1

# --- Connection / network ---
max_connections   = 200
bind-address      = 127.0.0.1
skip-name-resolve

# --- Socket / pidfile (must point at writable bind-mount paths) ---
socket            = /var/run/mysqld/mysqld.sock
pid-file          = /var/run/mysqld/mariadbd.pid

# --- Character set ---
# MOVES default DB ships as utf8 (3-byte) — keep that to round-trip.
character-set-server = utf8
collation-server     = utf8_general_ci

[mysqld_safe]
socket            = /var/run/mysqld/mysqld.sock

[client]
socket            = /var/run/mysqld/mysqld.sock
default-character-set = utf8
